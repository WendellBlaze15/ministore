# =========================================================
# Papier Lab - Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` to version control.
# =========================================================

# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Supabase - get these from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key   # SERVER ONLY - never expose to browser

# Supabase Storage bucket for product images (create in dashboard)
SUPABASE_STORAGE_BUCKET=product-images

# Admin email (the account that will be granted admin role)
ADMIN_EMAIL=admin@papierlab.shop

# Optional - app URL for emails / redirects
APP_URL=http://localhost:5000

# ---- Email / SMTP (for OTP password reset) ----
# Use a Gmail "App Password" (https://myaccount.google.com/apppasswords).
# Requires 2-factor authentication enabled on the sending Google account.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-shop@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your-shop@gmail.com
SMTP_FROM_NAME=Papier Lab
